rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Sabhi authenticated users ko read aur write ka access hai
    // Ye simple rules hain taaki app mein koi permission error na aaye
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Users collection ko login ke liye public read access chahiye
    match /users/{userId} {
      allow read: if true;
    }
  }
}
